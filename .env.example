# Dr Stone — environment template. Copy to `.env` and fill in real values.
# `.env` is git-ignored; this template is safe to commit (no secrets).

# Superuser provisioned on first startup (password is required to create it).
DRSTONE_SUPERUSER_EMAIL=you@institution.edu
DRSTONE_SUPERUSER_NAME=Your Name
DRSTONE_SUPERUSER_PASSWORD=change-me-strong-password

# Set to 1 to force the stored superuser password to match the value above on
# the next startup (rotate), then unset it again.
# DRSTONE_SUPERUSER_RESET=1

# Optional path overrides (otherwise computed relative to the repo).
# DRSTONE_DATA_DIR=
# DRSTONE_MODEL_DIR=
# DRSTONE_DICOM_ROOT=
# DRSTONE_CURATED_DIR=
